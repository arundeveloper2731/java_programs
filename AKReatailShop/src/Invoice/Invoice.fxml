<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="Invoice.InvoiceController"
            prefHeight="700.0" prefWidth="1100.0" style="-fx-background-color: #f2f4f9;">
    
    <left>
        <VBox prefWidth="220.0" style="-fx-background-color: #1a1d2e;" spacing="10">
            <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="P" style="-fx-background-color: #ff6b1a; -fx-text-fill: white; -fx-padding: 8; -fx-background-radius: 8; -fx-font-weight: bold;"/>
                <VBox>
                    <Label text="AK" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                    <Label text="Retail Shop" style="-fx-text-fill: #ff6b1a; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
            <Separator opacity="0.1"/>
            <Button text="📦 Stock Entry" style="-fx-background-color: #ff6b1a26; -fx-text-fill: #ff6b1a; -fx-alignment: CENTER_LEFT;" maxWidth="Infinity"/>
            <Button text="🏠 Dashboard" style="-fx-background-color: transparent; -fx-text-fill: #6b7290;" maxWidth="Infinity"/>
            </VBox>
    </left>

    <center>
        <VBox spacing="20">
            <padding><Insets top="20" left="25" right="25" bottom="20"/></padding>
            
            <HBox alignment="CENTER_LEFT" spacing="10">
                <VBox spacing="5">
                    <Label text="Stock Management / Receive Stock" style="-fx-font-size: 11; -fx-text-fill: #9ea6c0;"/>
                    <Label text="Receive New Stock" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0d0f1a;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Draft" style="-fx-background-color: #f0f2f8; -fx-border-color: #e0e4ef; -fx-border-radius: 8;"/>
            </HBox>

            <HBox spacing="15">
                <VBox spacing="15" prefWidth="550">
                    <VBox spacing="10" style="-fx-background-color: white; -fx-border-color: #e0e4ef; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 15;">
                        <Label text="🧾 INVOICE DETAILS" style="-fx-font-weight: bold; -fx-text-fill: #5a607a;"/>
                        <GridPane hgap="10" vgap="10">
                            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Invoice Number" style="-fx-font-size: 11;"/>
                                <TextField fx:id="invoiceNumField" text="INV-2024-0091" style="-fx-background-color: #f0f2f8; -fx-border-color: #ff6b1a;"/>
                            </VBox>
                            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Date" style="-fx-font-size: 11;"/>
                                <DatePicker fx:id="datePicker" />
                            </VBox>
                        </GridPane>
                        <Label text="Remarks" style="-fx-font-size: 11;"/>
                        <TextArea fx:id="remarksArea" prefHeight="60" promptText="Enter remarks..."/>
                    </VBox>

                    <VBox spacing="10" style="-fx-background-color: white; -fx-border-color: #e0e4ef; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 15;">
                        <Label text="📦 DELIVERY INFO" style="-fx-font-weight: bold; -fx-text-fill: #5a607a;"/>
                        <GridPane hgap="10" vgap="10">
                            <TextField fx:id="courierNameField" promptText="Courier Name" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <TextField fx:id="awbField" promptText="Tracking ID" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        </GridPane>
                    </VBox>
                </VBox>

                <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-border-color: #e0e4ef; -fx-border-radius: 12; -fx-background-radius: 12;">
                    <HBox alignment="CENTER_LEFT" style="-fx-padding: 10;">
                        <Label text="📋 PRODUCTS" style="-fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="+ Add" onAction="#handleAddProduct" style="-fx-background-color: #ff6b1a; -fx-text-fill: white;"/>
                    </HBox>
                    <TableView fx:id="productsTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="nameCol" text="PRODUCT" prefWidth="200"/>
                            <TableColumn fx:id="qtyCol" text="QTY" prefWidth="60"/>
                            <TableColumn fx:id="rateCol" text="RATE" prefWidth="100"/>
                            <TableColumn fx:id="totalCol" text="TOTAL" prefWidth="100"/>
                        </columns>
                    </TableView>
                    
                    <VBox spacing="5" style="-fx-background-color: #0d0f1a; -fx-padding: 15; -fx-background-radius: 0 0 12 12;">
                        <HBox alignment="CENTER_RIGHT" spacing="20">
                            <Label text="GRAND TOTAL" style="-fx-text-fill: rgba(255,255,255,0.6);"/>
                            <Label fx:id="grandTotalLabel" text="₹ 0.00" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
                        </HBox>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-background-color: white; -fx-padding: 10 25; -fx-border-color: #e0e4ef; -fx-border-width: 1.5 0 0 0;">
            <Button text="Cancel" style="-fx-background-color: #f0f2f8; -fx-border-color: #e0e4ef;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✓ Submit Stock" onAction="#handleSubmit" style="-fx-background-color: #0f9d58; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 25;"/>
        </HBox>
    </bottom>
</BorderPane>