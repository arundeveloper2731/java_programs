<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #f0ede8;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.phonezone.BillingController">
    
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0" spacing="20" style="-fx-background-color: white; -fx-border-color: #e8e5df; -fx-border-width: 0 0 1 0; -fx-padding: 0 30 0 30;">
            <VBox alignment="CENTER_LEFT">
                <Label style="-fx-font-size: 20; -fx-font-weight: 800;" text="New Sales Bill" />
                <Label style="-fx-text-fill: #8a8a9a;" text="PhoneZone Retail · Madurai" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="lblBillDate" style="-fx-font-weight: bold;" text="Date: 12-04-2026" />
        </HBox>
    </top>

    <center>
        <HBox spacing="20" style="-fx-padding: 20;">
            <VBox prefWidth="350.0" spacing="15" style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #e8e5df; -fx-border-radius: 12;">
                <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="Customer &amp; Product Details" />
                
                <VBox spacing="5">
                    <Label style="-fx-font-size: 11; -fx-text-fill: #8a8a9a;" text="CUSTOMER NAME" />
                    <TextField fx:id="txtCustomerName" promptText="Enter name" style="-fx-background-radius: 8;" />
                </VBox>

                <VBox spacing="5">
                    <Label style="-fx-font-size: 11; -fx-text-fill: #8a8a9a;" text="PRODUCT / MODEL" />
                    <ComboBox fx:id="cmbProduct" maxWidth="Infinity" promptText="Select Mobile Model" />
                </VBox>

                <HBox spacing="10">
                    <VBox HBox.hgrow="ALWAYS" spacing="5">
                        <Label style="-fx-font-size: 11; -fx-text-fill: #8a8a9a;" text="PRICE" />
                        <TextField fx:id="txtPrice" promptText="0.00" />
                    </VBox>
                    <VBox prefWidth="80" spacing="5">
                        <Label style="-fx-font-size: 11; -fx-text-fill: #8a8a9a;" text="QTY" />
                        <TextField fx:id="txtQty" text="1" />
                    </VBox>
                </HBox>

                <Button fx:id="btnAdd" maxWidth="Infinity" onAction="#addToCart" style="-fx-background-color: #ff6b35; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-background-radius: 8;" text="Add to Cart" />
            </VBox>

            <VBox spacing="15" HBox.hgrow="ALWAYS">
                <TableView fx:id="tblCart" VBox.vgrow="ALWAYS" style="-fx-background-radius: 12;">
                    <columns>
                        <TableColumn fx:id="colItem" prefWidth="250" text="Item Description" />
                        <TableColumn fx:id="colPrice" prefWidth="100" text="Price" />
                        <TableColumn fx:id="colQty" prefWidth="60" text="Qty" />
                        <TableColumn fx:id="colTotal" prefWidth="120" text="Total" />
                    </columns>
                </TableView>

                <VBox spacing="10" style="-fx-background-color: #1c1c24; -fx-background-radius: 12; -fx-padding: 20;">
                    <HBox>
                        <Label style="-fx-text-fill: #9a9aaa;" text="Subtotal" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblSubtotal" style="-fx-text-fill: white;" text="₹ 0.00" />
                    </HBox>
                    <HBox>
                        <Label style="-fx-text-fill: #9a9aaa;" text="GST (18%)" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblTax" style="-fx-text-fill: white;" text="₹ 0.00" />
                    </HBox>
                    <Separator opacity="0.1" />
                    <HBox alignment="CENTER_LEFT">
                        <Label style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: 800;" text="Grand Total" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblGrandTotal" style="-fx-text-fill: #ff9a3c; -fx-font-size: 22; -fx-font-weight: 800;" text="₹ 0.00" />
                    </HBox>
                    <Button maxWidth="Infinity" style="-fx-background-color: #22c55e; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8; -fx-font-size: 14;" text="PRINT &amp; SAVE BILL" />
                </VBox>
            </VBox>
        </HBox>
    </center>
</BorderPane>