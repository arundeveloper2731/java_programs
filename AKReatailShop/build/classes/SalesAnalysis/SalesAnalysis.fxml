<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="SalesAnalysis.SalesAnalysisController">
   
   <left>
      <VBox prefWidth="200.0" spacing="10.0" style="-fx-background-color: #1a1a2e;">
         <padding>
            <Insets bottom="20.0" left="15.0" right="15.0" top="20.0" />
         </padding>
         <children>
            <Label text="AK Mobile Shop" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="18.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
            </Label>
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Dashboard" />
            <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Sales Analysis" />
         </children>
      </VBox>
   </left>

   <center>
      <VBox spacing="15.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <Label text="Sales Analysis">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            
            <TableView fx:id="salesTable" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="dateCol" prefWidth="120.0" text="Date" />
                  <TableColumn fx:id="customerCol" prefWidth="200.0" text="Customer" />
                  <TableColumn fx:id="productCol" prefWidth="200.0" text="Product" />
                  <TableColumn fx:id="amountCol" prefWidth="120.0" text="Amount" />
               </columns>
            </TableView>
         </children>
      </VBox>
   </center>
</BorderPane>