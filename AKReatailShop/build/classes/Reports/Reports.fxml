<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="720.0" prefWidth="1100.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Reports.ReportsController">
    
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="80.0" spacing="20" style="-fx-background-color: white; -fx-padding: 0 30 0 30; -fx-border-color: #e8e5df; -fx-border-width: 0 0 1 0;">
            <VBox alignment="CENTER_LEFT">
                <Label style="-fx-font-size: 22; -fx-font-weight: 800;" text="Reports &amp; Analytics" />
                <Label style="-fx-text-fill: #8a8a9a;" text="Generate, export and schedule reports" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <TextField prefWidth="250.0" promptText="Search reports..." style="-fx-background-radius: 10; -fx-padding: 8;" />
            <Button onAction="#handleGenerateAll" style="-fx-background-color: #ff6b35; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 20;" text="Generate Report" />
        </HBox>
    </top>

    <center>
        <GridPane hgap="20" vgap="20" style="-fx-padding: 25;">
            <columnConstraints>
                <ColumnConstraints percentWidth="60" />
                <ColumnConstraints percentWidth="40" />
            </columnConstraints>

            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #e8e5df; -fx-border-radius: 15;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label style="-fx-font-size: 16; -fx-font-weight: bold;" text="Quick Reports" />
                
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                    <VBox fx:id="reportListContainer" spacing="12">
                        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 10; -fx-background-color: #fafafa; -fx-background-radius: 10;">
                            <StackPane prefWidth="40" prefHeight="40" style="-fx-background-color: rgba(255,107,53,0.1); -fx-background-radius: 8;">
                                <Label text="📊" />
                            </StackPane>
                            <VBox HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight: bold; -fx-font-size: 13;" text="Daily Sales Report" />
                                <Label style="-fx-font-size: 11; -fx-text-fill: #8a8a9a;" text="Today's complete transaction summary" />
                            </VBox>
                            <Button onAction="#handleReportAction" style="-fx-background-color: white; -fx-border-color: #e8e5df; -fx-border-radius: 8;" text="Generate" />
                        </HBox>
                        
                        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 10; -fx-background-color: #fafafa; -fx-background-radius: 10;">
                            <StackPane prefWidth="40" prefHeight="40" style="-fx-background-color: rgba(34,197,94,0.1); -fx-background-radius: 8;">
                                <Label text="📦" />
                            </StackPane>
                            <VBox HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight: bold; -fx-font-size: 13;" text="Stock / Inventory Report" />
                                <Label style="-fx-font-size: 11; -fx-text-fill: #8a8a9a;" text="Current stock levels and alerts" />
                            </VBox>
                            <Button onAction="#handleReportAction" style="-fx-background-color: white; -fx-border-color: #e8e5df; -fx-border-radius: 8;" text="Generate" />
                        </HBox>
                    </VBox>
                </ScrollPane>
            </VBox>

            <VBox spacing="20" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #e8e5df; -fx-border-radius: 15;">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 15;" text="Month-over-Month Revenue" />
                    <Label style="-fx-text-fill: #8a8a9a; -fx-font-size: 11;" text="2026 comparison" />
                    
                    <BarChart fx:id="revenueChart" legendSide="TOP" prefHeight="200.0">
                        <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                        <yAxis><NumberAxis side="LEFT" /></yAxis>
                    </BarChart>
                    
                    <HBox alignment="CENTER_LEFT" spacing="5">
                        <Label style="-fx-font-size: 11; -fx-text-fill: #8a8a9a;" text="YoY Growth: " />
                        <Label style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #22c55e;" text="+18.4%" />
                    </HBox>
                </VBox>

                <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #e8e5df; -fx-border-radius: 15;">
                    <Label style="-fx-font-weight: bold; -fx-font-size: 15;" text="Export Options" />
                    <Button maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-border-color: #e8e5df; -fx-border-radius: 8; -fx-padding: 10;" text="📄 Export as PDF" />
                    <Button maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-border-color: #e8e5df; -fx-border-radius: 8; -fx-padding: 10;" text="📊 Export as Excel (.xlsx)" />
                    <Button maxWidth="Infinity" alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-border-color: #e8e5df; -fx-border-radius: 8; -fx-padding: 10;" text="📧 Email Report" />
                </VBox>
            </VBox>
        </GridPane>
    </center>
</BorderPane>